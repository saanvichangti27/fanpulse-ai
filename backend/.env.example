# Copy to backend/.env and fill in. NEVER commit backend/.env or real keys.

# Google Gemini (aistudio.google.com/apikey) — used for campaign/content copy
GEMINI_API_KEY=your_gemini_key_here

# YouTube Data API v3 (console.cloud.google.com) — only needed for SOURCES=youtube
# (the capture script backend/ingestion/capture_youtube.py needs NO key)
YOUTUBE_API_KEY=your_youtube_key_here
YOUTUBE_VIDEO_ID=your_live_video_id_here

# Ingestion sources at startup: "replay" (default; driven via POST /replay/control)
# and/or "youtube" (poll the live chat of YOUTUBE_VIDEO_ID directly)
SOURCES=replay

# Industries that get an auto-campaign when a moment fires
AUTO_CAMPAIGN_INDUSTRIES=food_delivery,merch_apparel,beverages

# ---- Demo / UI integration (fake replay engine) ----
# Match the replay + UI bootstrap focus on
DEMO_MATCH_ID=m_001
# Start the replay automatically at boot (no manual POST /replay/control needed)
REPLAY_AUTOSTART=true
REPLAY_FILE=replay_dev_fixture.json
REPLAY_SPEED=1.0
# Restart the replay file forever (external_ids get a per-pass suffix)
REPLAY_LOOP=false
# Wipe the demo match's synthetic data at boot so every run tells the story fresh
REPLAY_RESET_ON_START=true
# Match-seconds per real second (dev fixture: 90' compressed into ~800s)
REPLAY_TIME_SCALE=6.75
# Browser origins allowed to call the API (frontend dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
