# Copy to backend/.env and fill in. NEVER commit backend/.env or real keys.

# Google Gemini (aistudio.google.com/apikey) — used for campaign/content copy
GEMINI_API_KEY=your_gemini_key_here

# YouTube Data API v3 (console.cloud.google.com) — only needed for SOURCES=youtube
# (the capture script backend/ingestion/capture_youtube.py needs NO key)
YOUTUBE_API_KEY=your_youtube_key_here
YOUTUBE_VIDEO_ID=your_live_video_id_here

# Ingestion sources at startup: "replay" (default; driven via POST /replay/control)
# and/or "youtube" (poll the live chat of YOUTUBE_VIDEO_ID directly)
SOURCES=replay

# Industries that get an auto-campaign when a moment fires
AUTO_CAMPAIGN_INDUSTRIES=food_delivery,merch_apparel,beverages
